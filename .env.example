# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/pl_sim

# Express server port (default: 3001)
PORT=3001

# Anthropic API key (for AI pyramid analysis feature)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Secret for signing local (non-O365) JWT tokens — generate with: openssl rand -hex 32
LOCAL_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Azure AD (for O365 authentication)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# Vite frontend env vars (must be prefixed with VITE_)
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_CLIENT_ID=your-client-id
